PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>
JWT_SECRET=replace_with_a_long_random_secret_never_commit_the_real_value
JWT_EXPIRE=7d
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# SMTP (used for password-reset emails). If unset, reset emails are logged to
# the server console instead of being sent — useful for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="EventSync <no-reply@eventsync.local>"
